# Copy to `.env` and adjust per machine / deployment (never commit `.env`).

# Truthy: 1, true, yes, on — logs code to server terminal only, no SMTP.
# Falsy or omitted: normal email path (SMTP_* if set, else [dev] console line).
VERIFICATION_EMAIL_BYPASS=true

# --- Real email delivery ---
# Use "inbox" to auto-apply Inbox.com SMTP defaults.
# You can also leave this empty and set SMTP_HOST/PORT manually.
SMTP_PROVIDER=inbox

# Optional overrides (used if set):
# SMTP_HOST=smtp.inbox.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls   # starttls | ssl | none

# Your Inbox.com mailbox credentials:
# SMTP_USER=your-inbox-username-or-email
# SMTP_PASSWORD=your-inbox-password
# SMTP_FROM=your-inbox-email
