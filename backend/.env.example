# Copy to `.env` and fill in real values (never commit `.env` with secrets).

# --- Email verification bypass (dev) ---
# VERIFICATION_EMAIL_BYPASS=false

# --- SMTP (Gmail: SMTP_PROVIDER=gmail + App Password; see backend/readme.md) ---
# SMTP_PROVIDER=gmail
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# Optional: SMTP_HOST, SMTP_PORT, SMTP_SECURITY (starttls | ssl | none)

# --- Admin console (JWT signing; set a long random secret in production) ---
# ADMIN_JWT_SECRET=

# --- MySQL (required unless SKIP_PREFLIGHT_CHECKS=true) ---
# Option A — single URL (encode special characters in password):
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME?charset=utf8mb4

# Option B — components:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_DB=your_database_name
# MYSQL_USER=your_mysql_user
# MYSQL_PASSWORD=your_mysql_password

# MYSQL_POOL_SIZE=5
# MYSQL_MAX_OVERFLOW=10
# MYSQL_POOL_RECYCLE=3600

# Dev only — do not use in production:
# SKIP_PREFLIGHT_CHECKS=true

# --- Quiz (PDF → Gemini MCQ) ---
# GEM_KEY=your_google_ai_studio_key
# Optional model override (default: gemini-2.5-flash):
# QUIZ_GEMINI_MODEL=gemini-2.5-flash
# Dev only — skip Gemini ping at startup (still need GEM_KEY to run a quiz):
# SKIP_GEMINI_PREFLIGHT=true
#
# Optional Redis cache (recommended): avoid repeated Gemini calls for the same PDF
# across different users/attempts. If not set, caching is disabled.
# REDIS_URL=redis://localhost:6379/0
# Cache TTL in seconds (default: 604800 = 7 days):
# QUIZ_CACHE_TTL_SECONDS=604800

# --- File logging (app.core.app_logger / loguru) ---
# LOG_DIR=./logs
# Minimum level to write to the daily log file (DEBUG, INFO, WARNING, ERROR):
# LOG_LEVEL=DEBUG
# Rotate when the current file exceeds this size (bytes split by loguru):
# LOG_ROTATION_MAX_MB=15
# Keep at most this many rotated files (older deleted):
# LOG_RETENTION_FILES=20
# Mirror the same log lines to stderr (default on). Set to false/off to disable:
# LOG_CONSOLE=false
# Minimum level for stderr (file still uses LOG_LEVEL):
# LOG_CONSOLE_LEVEL=INFO
# Async log sinks (thread per handler). Default off — avoids shutdown hangs with Ctrl+C:
# LOG_ENQUEUE=true
