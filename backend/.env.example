# Copy to `.env` and fill in real values (never commit `.env` with secrets).

# --- Email verification bypass (dev) ---
# VERIFICATION_EMAIL_BYPASS=false

# --- SMTP / Mailjet (see backend/readme.md) ---
# SMTP_PROVIDER=gmail
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# MJ_APIKEY_PUBLIC=
# MJ_APIKEY_PRIVATE=
# MJ_FROM_EMAIL=
# MJ_FROM_NAME=

# --- MySQL (required unless SKIP_PREFLIGHT_CHECKS=true) ---
# Option A — single URL (encode special characters in password):
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME?charset=utf8mb4

# Option B — components:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_DB=your_database_name
# MYSQL_USER=your_mysql_user
# MYSQL_PASSWORD=your_mysql_password

# MYSQL_POOL_SIZE=5
# MYSQL_MAX_OVERFLOW=10
# MYSQL_POOL_RECYCLE=3600

# Dev only — do not use in production:
# SKIP_PREFLIGHT_CHECKS=true

# --- Quiz (PDF → Gemini MCQ) ---
# GEM_KEY=your_google_ai_studio_key
# Optional model override (default: gemini-2.5-flash):
# QUIZ_GEMINI_MODEL=gemini-2.5-flash
# Dev only — skip Gemini ping at startup (still need GEM_KEY to run a quiz):
# SKIP_GEMINI_PREFLIGHT=true
