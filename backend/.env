# Copy to `.env` and adjust per machine / deployment (never commit `.env`).
GEM_KEY=key
# Truthy: 1, true, yes, on — logs code to server terminal only, no SMTP.
# Falsy or omitted: normal email path (SMTP_* if set, else [dev] console line).
VERIFICATION_EMAIL_BYPASS=false
 
# --- Real email delivery (SMTP) ---
# Use "gmail" or "inbox" for defaults, or leave SMTP_PROVIDER empty and set SMTP_HOST.
SMTP_PROVIDER=gmail
 
# Optional overrides (used if set):
# SMTP_HOST=smtp.inbox.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls   # starttls | ssl | none
 
# SMTP credentials (e.g. Gmail + App Password):
SMTP_USER=mukundhzg@gmail.com
SMTP_PASSWORD=pwd
SMTP_FROM=mukundhzg@gmail.com

# --- MySQL (user rows + preflight: server will not start until DB is reachable, unless SKIP_PREFLIGHT_CHECKS=true) ---
# Use ONE of: DATABASE_URL (recommended) OR the MYSQL_* block below.
#
# Option A — single connection string (password special chars must be URL-encoded, e.g. @ → %40):
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@127.0.0.1:3306/YOUR_DATABASE?charset=utf8mb4
#
# Option B — separate variables:
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=bigskill_db
MYSQL_USER=bigskilluser
MYSQL_PASSWORD=StrongPassword123!
#
# Optional pool tuning (defaults are fine for most apps):
MYSQL_POOL_SIZE=5
MYSQL_MAX_OVERFLOW=10
MYSQL_POOL_RECYCLE=3600
#
# Dev only — skip DB check at startup (do not use in production):
# SKIP_PREFLIGHT_CHECKS=true

#model name
QUIZ_GEMINI_MODEL=gemini-2.5-flash
SKIP_GEMINI_PREFLIGHT=true